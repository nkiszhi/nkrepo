[files]
model_path = ./data/model
train_add = ./data/features/train_features.csv
test_add = ./data/features/test_features.csv
hmm_add = ./data/hmm_matrix.csv
gib_add = ./data/gib_model.pki
gramfile_add = ./data/n_gram_rank_freq.txt
tld_add = ./data/tld.txt
white_file_add = ./data/sample/sample_white.csv
black_file_add = ./data/sample/sample_black.csv
feature_dir = ./data/features

[paths]
upload_dir = uploads
web_upload_dir = ../../data/web_upload_file
sample_root = ../../../sample-share/
zips_dir = ../../../data/zips

[feeds]
algorithm_list = knn,naivebayes,logisticregression,decisiontree,randomforest,adaboost,gbdt,xgboost
classifier_list = KNNClassifier,GNBClassifier,LRClassifier,DTClassifier,RFClassifier,ADABoostClassifier,GBDTClassifier,XGBoostClassifier

[ini]
ip = 0.0.0.0
port = 5004
row_per_page = 20

[jwt]
secret = CHANGE_THIS_TO_A_SECURE_RANDOM_STRING
expire_hours = 24

[mysql]
secret_key = CHANGE_THIS_TO_A_SECURE_RANDOM_STRING
sqlalchemy_database_uri = mysql+pymysql://username:password@localhost/database_name
sqlalchemy_track_modifications = False
host = 127.0.0.1
user = your_mysql_user
passwd = your_mysql_password
db = malicious
db_web = webdatadb
user_table = users
charset = utf8
db_category = category
db_family = family
db_platform = platform
db_benign = benign
db_domain = domain
db_component = api_component

[API]
# vt_key = your_virus_total_api_key_here

[fixed_user]
# username =
# password =

[flowviz]
# openai_api_key = your_openai_api_key_here
# openai_base_url = https://api.openai.com/v1
# openai_model = gpt-4
# claude_api_key = your_claude_api_key_here
# claude_base_url = https://api.anthropic.com
# claude_model = claude-3-opus-20240229
# default_ai_provider = openai

max_request_size = 10485760
max_image_size = 3145728
max_article_size = 5242880

log_level = INFO
log_file = flowviz.log

parse_max_nodes = 50
parse_max_edges = 40
parse_min_nodes = 10
parse_min_edges = 8

openai_max_tokens_multiplier = 2.5
openai_min_tokens = 8192
openai_max_tokens = 65536
openai_temperature = 0.1

[api]
baseUrl = http://127.0.0.1:5005
prefix = /api

[docker_models]
# Docker API 基础地址
api_base = http://127.0.0.1

# Docker 模型端口配置
# 格式: 模型名 = 端口号
ember = 8000
malconv = 8001
imcfn = 8002
malconv2 = 8003
transformer = 8004
inceptionv3 = 8005
rcnf = 8006
onedense_cnn = 8007
malgraph = 8008

# API 超时时间(秒)
timeout = 30
